# Copy to .env and fill in. .env is gitignored.
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional. Defaults to a NATIVE Japanese voice (important: English voices keep
# an English accent when reading Japanese, which is bad for listening practice).
#   Asahi  (male, calm, conversational) = C8e2F6Cm3l58PjXaVpUW   <- default
#   Konoha (female, JP explainer)       = T7yYq3WpB94yAuOXraRi
# Browse more: https://elevenlabs.io/app/voice-library  (filter Language = Japanese)
ELEVENLABS_VOICE_ID=

# Optional. Model + output format. Defaults shown.
# eleven_multilingual_v2 is high quality + stable. eleven_v3 is newest/most expressive.
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
